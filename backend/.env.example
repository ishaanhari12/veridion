# ─────────────────────────────────────────────────────────────
# Copy this file to .env:   cp .env.example .env
# .env is gitignored and will never be committed.
# ─────────────────────────────────────────────────────────────

ENVIRONMENT=development

# Database
POSTGRES_USER=veridion
POSTGRES_PASSWORD=veridion_secret
POSTGRES_DB=veridion
DATABASE_URL=postgresql://veridion:veridion_secret@db:5432/veridion
TEST_DATABASE_URL=postgresql://veridion:veridion_secret@db:5432/veridion_test

# JWT Secret Key
# Generate one by running:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then paste the output as the value below.
SECRET_KEY=CHANGE_ME_generate_a_real_32_char_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fraud service
FRAUD_SERVICE_URL=http://fraud:8001
FRAUD_BLOCK_THRESHOLD=0.85
FRAUD_FLAG_THRESHOLD=0.50
